{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "cpu-debug",
      "displayName": "CPU Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/cpu-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-march=native",
        "CMAKE_CXX_FLAGS_DEBUG": "-O2 -g",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "COILGUN_BUILD_TESTS": "ON",
        "COILGUN_BUILD_GENERATOR_TESTS": "ON",
        "COILGUN_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "cpu-release",
      "displayName": "CPU Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/cpu-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-march=native",
        "COILGUN_BUILD_TESTS": "ON",
        "COILGUN_BUILD_GENERATOR_TESTS": "ON",
        "COILGUN_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "cuda-debug",
      "displayName": "CUDA Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/cuda-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-march=native",
        "CMAKE_CXX_FLAGS_DEBUG": "-O2 -g",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "COILGUN_BUILD_TESTS": "ON",
        "COILGUN_BUILD_GENERATOR_TESTS": "ON",
        "COILGUN_ENABLE_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    },
    {
      "name": "cuda-release",
      "displayName": "CUDA Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/cuda-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-march=native",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "COILGUN_BUILD_TESTS": "ON",
        "COILGUN_BUILD_GENERATOR_TESTS": "ON",
        "COILGUN_ENABLE_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "cpu-debug",
      "displayName": "CPU Debug",
      "configurePreset": "cpu-debug"
    },
    {
      "name": "cpu-release",
      "displayName": "CPU Release",
      "configurePreset": "cpu-release"
    },
    {
      "name": "cuda-debug",
      "displayName": "CUDA Debug",
      "configurePreset": "cuda-debug"
    },
    {
      "name": "cuda-release",
      "displayName": "CUDA Release",
      "configurePreset": "cuda-release"
    }
  ],
  "testPresets": [
    {
      "name": "cpu-debug",
      "displayName": "CPU Debug Tests",
      "configurePreset": "cpu-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cpu-release",
      "displayName": "CPU Release Tests",
      "configurePreset": "cpu-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cuda-debug",
      "displayName": "CUDA Debug Tests",
      "configurePreset": "cuda-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cuda-release",
      "displayName": "CUDA Release Tests",
      "configurePreset": "cuda-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
